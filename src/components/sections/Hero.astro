---
import { Image } from "astro:assets";
import Container from "../shared/Container.astro";
import fotoHero from "../../assets/images/fotohero.jpeg";

export interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<section class={`relative pt-18 lg:pt-36 ${className}`}>
  <Container className={"flex flex-col-reverse lg:flex-row gap-10 lg:gap-12"}>
    <div
      class="relative flex flex-col items-center text-center lg:text-left lg:py-7 xl:py-8
        lg:items-start lg:max-w-none max-w-3xl mx-auto lg:mx-0 lg:flex-1 lg:w-1/2"
    >
      <h1
        class="text-3xl/tight sm:text-4xl/tight md:text-5xl/tight xl:text-6xl/tight
             font-bold text-heading-1"
      >
       Ucapkan Selamat Tinggal pada Rayap 
        <br /> <span class="text-primary">dan Kusen Keropos.</span>
      </h1>
      <p class="text-heading-3 text-lg md:text-xl leading-relaxed max-w-xl mt-8">
       Hadirkan kenyamanan keluarga melalui produk aluminium yang memadukan desain elegan dan material tahan lama, dengan jaminan pemasangan pintu, jendela, hingga kitchen set yang rapi dan presisi agar rumah Anda tetap kokoh tanpa perlu renovasi berulang kali.

      <div class="mt-10 flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start w-full">
        <a href="#products" class="inline-flex items-center justify-center w-full sm:w-max px-8 py-3.5 rounded-full bg-primary text-white text-base font-semibold hover:bg-opacity-90 hover:shadow-secondary/20 transition-all shadow-lg shadow-primary/20">
          Lihat Hasil Produk
          <svg class="w-5 h-5 ml-2 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7V17"/></svg>
        </a>
        <a href="#cta" class="inline-flex items-center justify-center w-full sm:w-max px-8 py-3.5 rounded-full border-2 border-box-border text-heading-1 text-base font-semibold hover:border-secondary hover:text-secondary hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">
          Konsultasi Gratis
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7V17"/></svg>
        </a>
      </div>
    </div>

    <div
      class="flex flex-1 lg:w-1/2 lg:h-auto relative lg:max-w-none lg:mx-0 mx-auto max-w-3xl"
    >
      <Image
        src={fotoHero}
        alt="Agung Jaya Aluminium"
        class="lg:absolute lg:w-full lg:h-full rounded-3xl object-cover aspect-square lg:aspect-auto w-full shadow-xl shadow-slate-200/50 dark:shadow-slate-900/50"
      />
    </div>
  </Container>
</section>

