---
import Container from "../shared/Container.astro";
import { products } from "../../utils/data.ts";

export interface Props {
    className?: string;
}

const { className } = Astro.props;

// Group products in chunks of 4 for the asymmetric grid (1 tall left + 1 wide top-right + 2 small bottom-right)
const blocks: typeof products[] = [];
for (let i = 0; i < products.length; i += 4) {
    blocks.push(products.slice(i, i + 4));
}
---

<section id="products" class={`relative reveal ${className}`}>
    <Container>
        <!-- Header: title left, description right - exactly like reference -->
        <div class="flex flex-col items-center text-center gap-4 mb-10">
            <h2 class="text-4xl md:text-5xl font-bold text-heading-1 leading-tight">
                Model Aluminium
                <span class="text-primary"> Karya Kami</span>
            </h2>
            <p class="text-heading-3 max-w-2xl text-sm md:text-base leading-relaxed">
                Jelajahi berbagai model dan desain aluminium premium untuk kebutuhan hunian Anda. Kualitas unggul, desain elegan, dan pengerjaan presisi.
            </p>
        </div>
    </Container>

    <!-- Horizontal scrollable grid blocks -->
    <div id="product-carousel" class="overflow-x-auto snap-x snap-mandatory hide-scroll-bar">
        <div class="flex w-max">
            {blocks.map((block, blockIdx) => (
                <div 
                    class={`product-block snap-center flex-shrink-0 w-screen px-6 md:px-10 lg:px-[max(3vw,calc((100vw-72rem)/2))] transition-all duration-700 ${blockIdx > 0 ? 'opacity-0 translate-x-8' : ''}`}
                    data-block={blockIdx}
                >
                    <!-- Asymmetric Grid: left tall + right (top wide + 2 bottom) -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5 h-auto md:h-[520px]">
                        
                        {/* LEFT: Tall image */}
                        {block[0] && (
                            <div class="relative rounded-2xl overflow-hidden bg-slate-200 dark:bg-slate-700 h-[350px] md:h-full group">
                                <div class="absolute inset-0 flex flex-col items-center justify-center text-slate-400 dark:text-slate-500">
                                    <svg class="w-8 h-8 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                    </svg>
                                    <span class="text-sm font-medium">{block[0].title}</span>
                                </div>
                                {/* <img src={block[0].image} alt={block[0].title} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" /> */}
                                <div class="absolute top-4 right-4 bg-white/80 backdrop-blur-sm w-10 h-10 rounded-full flex items-center justify-center cursor-pointer hover:bg-white transition-all shadow-sm z-10">
                                    <svg class="w-5 h-5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                                    </svg>
                                </div>
                            </div>
                        )}

                        {/* RIGHT column */}
                        <div class="flex flex-col gap-4 md:gap-5 h-auto md:h-full">
                            {/* Top - wide image */}
                            {block[1] && (
                                <div class="relative rounded-2xl overflow-hidden bg-slate-200 dark:bg-slate-700 h-[250px] md:flex-1 group">
                                    <div class="absolute inset-0 flex flex-col items-center justify-center text-slate-400 dark:text-slate-500">
                                        <svg class="w-8 h-8 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                        </svg>
                                        <span class="text-sm font-medium">{block[1].title}</span>
                                    </div>
                                    {/* <img src={block[1].image} alt={block[1].title} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" /> */}
                                    <div class="absolute top-4 right-4 bg-white/80 backdrop-blur-sm w-10 h-10 rounded-full flex items-center justify-center cursor-pointer hover:bg-white transition-all shadow-sm z-10">
                                        <svg class="w-5 h-5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                                        </svg>
                                    </div>
                                </div>
                            )}

                            {/* Bottom - 2 equal images */}
                            <div class="grid grid-cols-2 gap-4 md:gap-5 md:flex-1">
                                {block[2] && (
                                    <div class="relative rounded-2xl overflow-hidden bg-slate-200 dark:bg-slate-700 h-[200px] md:h-full group">
                                        <div class="absolute inset-0 flex flex-col items-center justify-center text-slate-400 dark:text-slate-500">
                                            <svg class="w-6 h-6 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                            </svg>
                                            <span class="text-xs font-medium">{block[2].title}</span>
                                        </div>
                                        {/* <img src={block[2].image} alt={block[2].title} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" /> */}
                                        <div class="absolute top-3 right-3 bg-white/80 backdrop-blur-sm w-8 h-8 rounded-full flex items-center justify-center cursor-pointer hover:bg-white transition-all shadow-sm z-10">
                                            <svg class="w-4 h-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                                            </svg>
                                        </div>
                                    </div>
                                )}

                                {block[3] && (
                                    <div class="relative rounded-2xl overflow-hidden bg-slate-200 dark:bg-slate-700 h-[200px] md:h-full group">
                                        <div class="absolute inset-0 flex flex-col items-center justify-center text-slate-400 dark:text-slate-500">
                                            <svg class="w-6 h-6 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                            </svg>
                                            <span class="text-xs font-medium">{block[3].title}</span>
                                        </div>
                                        {/* <img src={block[3].image} alt={block[3].title} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" /> */}
                                        <div class="absolute top-3 right-3 bg-white/80 backdrop-blur-sm w-8 h-8 rounded-full flex items-center justify-center cursor-pointer hover:bg-white transition-all shadow-sm z-10">
                                            <svg class="w-4 h-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                                            </svg>
                                        </div>
                                    </div>
                                )}
                            </div>
                        </div>

                    </div>
                </div>
            ))}
        </div>
    </div>

    <!-- Dot indicators -->
    {blocks.length > 1 && (
        <div class="flex justify-center gap-2 mt-6">
            {blocks.map((_, i) => (
                <button 
                    class={`carousel-dot w-2.5 h-2.5 rounded-full transition-all duration-300 ${i === 0 ? 'bg-gradient-to-r from-primary to-secondary w-8' : 'bg-slate-300 dark:bg-slate-600'}`}
                    data-dot={i}
                    aria-label={`Slide ${i + 1}`}
                />
            ))}
        </div>
    )}

    <style>
        .hide-scroll-bar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        .hide-scroll-bar::-webkit-scrollbar {
            display: none;
        }
    </style>

    <script>
        const carousel = document.getElementById('product-carousel');
        if (carousel) {
            const blocks = carousel.querySelectorAll('.product-block');
            const dots = document.querySelectorAll('.carousel-dot');

            const revealOnScroll = () => {
                const containerRect = carousel.getBoundingClientRect();

                blocks.forEach((block, idx) => {
                    const blockRect = block.getBoundingClientRect();
                    // If block is at least partially visible
                    if (blockRect.left < containerRect.right && blockRect.right > containerRect.left) {
                        block.classList.remove('opacity-0', 'translate-x-8');
                        block.classList.add('opacity-100', 'translate-x-0');
                    }
                });

                // Update dots based on scroll position
                if (dots.length > 0) {
                    const scrollLeft = carousel.scrollLeft;
                    const blockWidth = (blocks[0] as HTMLElement).offsetWidth;
                    const activeIndex = Math.round(scrollLeft / blockWidth);

                    dots.forEach((dot, i) => {
                        if (i === activeIndex) {
                            dot.classList.add('bg-gradient-to-r', 'from-primary', 'to-secondary', 'w-8');
                            dot.classList.remove('bg-slate-300', 'dark:bg-slate-600');
                        } else {
                            dot.classList.remove('bg-gradient-to-r', 'from-primary', 'to-secondary', 'w-8');
                            dot.classList.add('bg-slate-300', 'dark:bg-slate-600');
                        }
                    });
                }
            };

            carousel.addEventListener('scroll', revealOnScroll);
            revealOnScroll();

            // Dot click navigation
            dots.forEach((dot, i) => {
                dot.addEventListener('click', () => {
                    const blockWidth = (blocks[0] as HTMLElement).offsetWidth;
                    carousel.scrollTo({ left: blockWidth * i, behavior: 'smooth' });
                });
            });
        }
    </script>
</section>
