---
import Container from "../shared/Container.astro";
import { products } from "../../utils/data.ts";

export interface Props {
    className?: string;
}

const { className } = Astro.props;
---

<section id="products" class={`relative reveal ${className}`}>
    <Container>
        <!-- Header: title left, description right -->
        <div class="flex flex-col items-center text-center gap-4 mb-10">
            <h2 class="text-4xl md:text-5xl font-bold text-heading-1 leading-tight">
                Model Aluminium
                <span class="text-primary"> Karya Kami</span>
            </h2>
            <p class="text-heading-3 max-w-2xl text-sm md:text-base leading-relaxed">
                Jelajahi berbagai model dan desain aluminium premium untuk kebutuhan hunian Anda. Kualitas unggul, desain elegan, dan pengerjaan presisi.
            </p>
        </div>

        <!-- Horizontal scrollable grid blocks -->
        <div class="relative w-full mt-10">
            <div id="product-carousel" class="flex overflow-x-auto snap-x snap-mandatory gap-6 hide-scroll-bar pb-8 -mx-4 px-4 sm:mx-0 sm:px-0">
                {products.map((product) => (
                    <div class="product-item snap-center shrink-0 w-[85vw] sm:w-[calc(50%-0.75rem)] lg:w-[calc(25%-1.125rem)]">
                        <div class="group flex flex-col bg-white dark:bg-slate-800 rounded-[2rem] overflow-hidden shadow-[0_8px_30px_rgb(0,0,0,0.04)] dark:shadow-none border border-slate-100 dark:border-slate-800 hover:shadow-xl transition-all duration-500 hover:-translate-y-1 h-full">
                            
                            <!-- Product Image Header -->
                            <div class="relative w-full aspect-[4/5] bg-slate-100 dark:bg-slate-700 overflow-hidden">
                                {product.image ? (
                                    <img 
                                        src={`/products/${product.image}`} 
                                        alt={product.title} 
                                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" 
                                    />
                                ) : (
                                    <div class="w-full h-full flex flex-col items-center justify-center text-slate-400">
                                        <svg class="w-8 h-8 mb-2 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                        </svg>
                                        <span class="text-sm font-medium">Gambar Tidak Tersedia</span>
                                    </div>
                                )}
                                
                                <!-- Wishlist/Favorite Icon -->
                                <div class="absolute top-4 right-4 w-9 h-9 bg-white/90 dark:bg-slate-800/90 backdrop-blur-md rounded-full flex items-center justify-center cursor-pointer text-slate-400 hover:text-red-500 hover:bg-white transition-all shadow-sm z-10">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                                    </svg>
                                </div>
                            </div>

                            <!-- Product Info Body -->
                            <div class="p-5 flex-1 flex flex-col">
                                <h3 class="text-heading-1 font-bold text-lg mb-1 group-hover:text-primary transition-colors">
                                    {product.title}
                                </h3>
                                <p class="text-heading-3 text-sm line-clamp-2">
                                    Pilihan desain {product.title.toLowerCase()} minimalis dengan kualitas material yang kokoh dan tahan korosi.
                                </p>
                            </div>
                            
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </Container>

    <!-- Navigation Elements -->
    {products.length > 4 && (
        <div class="flex items-center justify-center gap-6 mt-4">
            <!-- Prev Button -->
            <button id="carousel-prev" class="flex w-12 h-12 rounded-full border border-slate-200 dark:border-slate-800 items-center justify-center text-slate-500 hover:text-primary hover:border-primary transition-all hover:bg-slate-50 dark:hover:bg-slate-800/50 hover:-translate-x-1" aria-label="Previous slide">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
            </button>

            <!-- Next Button -->
            <button id="carousel-next" class="flex w-12 h-12 rounded-full border border-slate-200 dark:border-slate-800 items-center justify-center text-slate-500 hover:text-primary hover:border-primary transition-all hover:bg-slate-50 dark:hover:bg-slate-800/50 hover:translate-x-1" aria-label="Next slide">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            </button>
        </div>
    )}

    <style>
        .hide-scroll-bar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        .hide-scroll-bar::-webkit-scrollbar {
            display: none;
        }
    </style>

    <script>
        const carousel = document.getElementById('product-carousel');
        if (carousel) {
            const items = carousel.querySelectorAll('.product-item');
            const btnPrev = document.getElementById('carousel-prev');
            const btnNext = document.getElementById('carousel-next');

            if (btnPrev && btnNext && items.length > 0) {
                // Determine width of one item + gap
                const getScrollAmount = () => {
                    const itemWidth = (items[0] as HTMLElement).offsetWidth;
                    // Gap is 1.5rem (24px)
                    return itemWidth + 24; 
                };

                btnPrev.addEventListener('click', () => {
                    carousel.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
                });

                btnNext.addEventListener('click', () => {
                    carousel.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
                });
            }
        }
    </script>
</section>
