---
import Container from "../shared/Container.astro";
import { products } from "../../utils/data.ts";

export interface Props {
    className?: string;
}

const { className } = Astro.props;
---

<section id="products" class={`relative reveal ${className}`}>
    <Container>
        <!-- Header: title left, description right -->
        <div class="flex flex-col items-center text-center gap-4 mb-10">
            <h2 class="text-4xl md:text-5xl font-bold text-heading-1 leading-tight">
                Beberapa Hasil 
                <span class="text-primary"> Pengerjaan Kami</span>
            </h2>
            <p class="text-heading-3 max-w-2xl text-sm md:text-base leading-relaxed">
                Jelajahi berbagai model dan desain aluminium premium untuk kebutuhan hunian Anda. Kualitas unggul, desain elegan, dan pengerjaan presisi.Untuk model yang tidak ada di sini bisa cek ke Instagram kami @agungjaya_aluminiumm.
            </p>
        </div>

        <!-- Horizontal scrollable grid blocks -->
        <div class="relative w-full mt-10">
            <div id="product-carousel" class="flex overflow-x-auto snap-x snap-mandatory gap-6 hide-scroll-bar pb-8 -mx-4 px-4 sm:mx-0 sm:px-0">
                {products.map((product) => (
                    <div class="product-item snap-center shrink-0 w-[85vw] sm:w-[calc(50%-0.75rem)] lg:w-[calc(25%-1.125rem)]">
                        <div class="group flex flex-col bg-white dark:bg-slate-800 rounded-[2rem] overflow-hidden shadow-[0_8px_30px_rgb(0,0,0,0.04)] dark:shadow-none border border-slate-100 dark:border-slate-800 hover:shadow-xl transition-all duration-500 hover:-translate-y-1 h-full">
                            
                            <!-- Product Image Header -->
                            <div class="relative w-full aspect-[4/5] bg-slate-100 dark:bg-slate-700 overflow-hidden">
                                {product.image ? (
                                    <img 
                                        src={`/products/${product.image}`} 
                                        alt={product.title} 
                                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" 
                                    />
                                ) : (
                                    <div class="w-full h-full flex flex-col items-center justify-center text-slate-400">
                                        <svg class="w-8 h-8 mb-2 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                        </svg>
                                        <span class="text-sm font-medium">Gambar Tidak Tersedia</span>
                                    </div>
                                )}
                                
                                <!-- Wishlist/Favorite Icon -->
                                <div class="absolute top-4 right-4 w-9 h-9 bg-white/90 dark:bg-slate-800/90 backdrop-blur-md rounded-full flex items-center justify-center cursor-pointer text-slate-400 hover:text-red-500 hover:bg-white transition-all shadow-sm z-10">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                                    </svg>
                                </div>
                            </div>

                            <!-- Product Info Body -->
                            <div class="p-5 flex-1 flex flex-col">
                                <h3 class="text-heading-1 font-bold text-lg mb-1 group-hover:text-primary transition-colors">
                                    {product.title}
                                </h3>
                                <p class="text-heading-3 text-sm line-clamp-2">
                                    {product.description}
                                </p>
                                <div class="mt-auto pt-4 flex">
                                    <button 
                                        class="text-primary text-sm font-semibold flex items-center gap-1 hover:gap-2 transition-all btn-detail outline-none"
                                        data-title={product.title}
                                        data-desc={product.description}
                                        data-img={product.image || ''}
                                    >
                                        Lihat Detail
                                        <svg class="w-4 h-4 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                                    </button>
                                </div>
                            </div>
                            
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </Container>

    <!-- Navigation Elements -->
    {products.length > 4 && (
        <div class="flex items-center justify-center gap-6 mt-4">
            <!-- Prev Button -->
            <button id="carousel-prev" class="flex w-12 h-12 rounded-full border border-slate-200 dark:border-slate-800 items-center justify-center text-slate-500 hover:text-primary hover:border-primary transition-all hover:bg-slate-50 dark:hover:bg-slate-800/50 hover:-translate-x-1" aria-label="Previous slide">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
            </button>

            <!-- Next Button -->
            <button id="carousel-next" class="flex w-12 h-12 rounded-full border border-slate-200 dark:border-slate-800 items-center justify-center text-slate-500 hover:text-primary hover:border-primary transition-all hover:bg-slate-50 dark:hover:bg-slate-800/50 hover:translate-x-1" aria-label="Next slide">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            </button>
        </div>
    )}

    <!-- Product Detail Modal -->
    <dialog id="product-modal" class="backdrop:bg-slate-900/60 p-0 rounded-2xl shadow-2xl border border-slate-100 dark:border-slate-800 w-[90vw] max-w-lg bg-white dark:bg-slate-900 hidden open:block custom-dialog">
        <div class="relative flex flex-col max-h-[85vh]">
            <button id="modal-close" class="absolute top-4 right-4 z-10 w-9 h-9 flex items-center justify-center bg-black/40 hover:bg-black/60 text-white rounded-full transition-colors backdrop-blur-md">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
            <div class="w-full aspect-[4/5] sm:h-[45vh] sm:aspect-auto bg-slate-100 dark:bg-slate-800 flex items-center justify-center shrink-0">
                <img id="modal-img" src="" alt="Product Image" class="w-full h-full object-cover" />
                <svg id="modal-img-placeholder" class="w-12 h-12 text-slate-400 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <div class="p-6 md:p-8 overflow-y-auto">
                <h3 id="modal-title" class="text-2xl font-bold text-heading-1 mb-4"></h3>
                <p id="modal-desc" class="text-heading-3 leading-relaxed text-sm md:text-base"></p>
                <div class="mt-8 flex justify-end w-full">
                    <button id="modal-close-btn" class="px-6 py-2 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-heading-2 rounded-full font-medium transition-colors">Tutup</button>
                </div>
            </div>
        </div>
    </dialog>

    <style>
        .hide-scroll-bar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        .hide-scroll-bar::-webkit-scrollbar {
            display: none;
        }
        
        /* Modal animations */
        .custom-dialog[open] {
            animation: showModal 0.3s ease normal;
        }
        @keyframes showModal {
            from { opacity: 0; transform: scale(0.95); }
            to { opacity: 1; transform: scale(1); }
        }
        .custom-dialog::backdrop {
            animation: showBackdrop 0.3s ease normal;
        }
        @keyframes showBackdrop {
            from { opacity: 0; }
            to { opacity: 1; }
        }
    </style>

    <script>
        const carousel = document.getElementById('product-carousel');
        if (carousel) {
            const items = carousel.querySelectorAll('.product-item');
            const btnPrev = document.getElementById('carousel-prev');
            const btnNext = document.getElementById('carousel-next');

            if (btnPrev && btnNext && items.length > 0) {
                const getScrollAmount = () => {
                    const itemWidth = (items[0] as HTMLElement).offsetWidth;
                    return itemWidth + 24; 
                };

                btnPrev.addEventListener('click', () => {
                    carousel.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
                });

                btnNext.addEventListener('click', () => {
                    carousel.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
                });
            }
        }

        // Modal Logic
        const modal = document.getElementById('product-modal') as HTMLDialogElement;
        const detailBtns = document.querySelectorAll('.btn-detail');
        const modalImg = document.getElementById('modal-img') as HTMLImageElement;
        const modalPlaceholder = document.getElementById('modal-img-placeholder');
        const modalTitle = document.getElementById('modal-title');
        const modalDesc = document.getElementById('modal-desc');
        const modalClose = document.getElementById('modal-close');
        const modalCloseBtn = document.getElementById('modal-close-btn');

        if (modal) {
            detailBtns.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const target = e.currentTarget as HTMLElement;
                    const title = target.getAttribute('data-title');
                    const desc = target.getAttribute('data-desc');
                    const img = target.getAttribute('data-img');

                    if (modalTitle) modalTitle.textContent = title;
                    if (modalDesc) modalDesc.textContent = desc;

                    if (img) {
                        modalImg.src = `/products/${img}`;
                        modalImg.classList.remove('hidden');
                        if (modalPlaceholder) modalPlaceholder.classList.add('hidden');
                    } else {
                        modalImg.src = '';
                        modalImg.classList.add('hidden');
                        if (modalPlaceholder) modalPlaceholder.classList.remove('hidden');
                    }

                    modal.showModal();
                    document.body.style.overflow = 'hidden';
                });
            });

            const closeAction = () => {
                modal.close();
                document.body.style.overflow = '';
            };
            
            if (modalClose) modalClose.addEventListener('click', closeAction);
            if (modalCloseBtn) modalCloseBtn.addEventListener('click', closeAction);
            
            modal.addEventListener('click', (e) => {
                const rect = modal.getBoundingClientRect();
                if (
                    e.clientX < rect.left ||
                    e.clientX > rect.right ||
                    e.clientY < rect.top ||
                    e.clientY > rect.bottom
                ) {
                    closeAction();
                }
            });
        }
    </script>
</section>
