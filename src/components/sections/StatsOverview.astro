---
import Container from "../shared/Container.astro";
---

<section class="relative pt-16 md:pt-20 pb-12 reveal">
  <Container>
    <!-- Header aligned to same 12-col grid as content below -->
    <div
      class="grid grid-cols-1 lg:grid-cols-12 gap-4 md:gap-6 mb-10 items-end"
    >
      <div class="col-span-1 lg:col-span-6">
        <h2
          class="text-heading-1 text-3xl sm:text-4xl md:text-[2.75rem] font-bold mt-2 leading-[1.2]"
        >
          <span class="text-primary">Bukti Nyata </span> Pekerjaan <br />
          Kami <span class="text-secondary">Dipercaya Ratusan Rumah</span>
        </h2>
      </div>
      <div class="col-span-1 lg:col-span-6 lg:pl-10">
        <p class="text-heading-3 text-sm sm:text-lg max-w-md opacity-80">
          Memberikan pelayanan terbaik dengan selalu mengutamakan kerapian, kekuatan material, dan ketepatan waktu. Berikut adalah perjalanan kami melayani pelanggan.
        </p>
      </div>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 md:gap-6">
      <!-- Left 2x2 Stats -->
      <div
        class="col-span-1 lg:col-span-6 grid grid-cols-2 gap-3 sm:gap-4 md:gap-6"
      >
        <!-- Stat 1 (Dark) -->
        <div
          class="p-4 sm:p-5 md:p-6 rounded-[1rem] md:rounded-[2rem] bg-primary text-white shadow-lg shadow-primary/20 flex flex-col justify-center transform hover:-translate-y-1 transition-transform"
        >
          <h3
            class="text-3xl sm:text-4xl md:text-5xl font-bold mb-1 sm:mb-2 md:mb-3 text-white"
          >
            10K+
          </h3>
          <p class="text-xs sm:text-sm md:text-base text-blue-100 font-medium">
            Followers on TikTok
          </p>
        </div>
        <!-- Stat 2 -->
        <div
          class="p-4 sm:p-5 md:p-6 rounded-[1rem] md:rounded-[2rem] bg-box-bg border border-box-border text-heading-1 shadow-lg shadow-box-shadow flex flex-col justify-center transform hover:-translate-y-1 transition-transform"
        >
          <h3
            class="text-3xl sm:text-4xl md:text-5xl font-bold mb-1 sm:mb-2 md:mb-3 text-heading-1"
          >
            20+
          </h3>
          <p class="text-xs sm:text-sm md:text-base text-heading-3 font-medium">
            Tahun Pengalaman
          </p>
        </div>
        <!-- Stat 3 -->
        <div
          class="p-4 sm:p-5 md:p-6 rounded-[1rem] md:rounded-[2rem] bg-box-bg border border-box-border text-heading-1 shadow-lg shadow-box-shadow flex flex-col justify-center transform hover:-translate-y-1 transition-transform"
        >
          <h3
            class="text-3xl sm:text-4xl md:text-5xl font-bold mb-1 sm:mb-2 md:mb-3 text-heading-1"
          >
            150+
          </h3>
          <p class="text-xs sm:text-sm md:text-base text-heading-3 font-medium">
            Proyek Selesai
          </p>
        </div>
        <!-- Stat 4 -->
        <div
          class="p-4 sm:p-5 md:p-6 rounded-[1rem] md:rounded-[2rem] bg-box-bg border border-box-border text-heading-1 shadow-lg shadow-box-shadow flex flex-col justify-center transform hover:-translate-y-1 transition-transform"
        >
          <h3
            class="text-3xl sm:text-4xl md:text-5xl font-bold mb-1 sm:mb-2 md:mb-3 text-heading-1"
          >
            25+
          </h3>
          <p class="text-xs sm:text-sm md:text-base text-heading-3 font-medium">
            Koleksi Model Desain
          </p>
        </div>
      </div>

      <!-- Right Feature Card -->
      <div
        class="col-span-1 lg:col-span-6 bg-box-bg border border-box-border shadow-lg shadow-box-shadow rounded-[2rem] flex flex-col sm:flex-row overflow-hidden transform hover:-translate-y-1 transition-transform relative"
      >
        <div
          class="p-6 sm:p-7 md:p-8 flex-1 flex flex-col justify-center items-start"
        >
          <p
            class="text-base sm:text-lg md:text-xl font-medium text-heading-2 leading-relaxed mb-4 sm:mb-8 max-w-md"
          >
            Dari pintu sampai kitchen set, serahkan pada tim berpengalaman kami.
            Hasil dijamin pas, rapi, dan awet tanpa perlu repot perawatan.
          </p>
          
          <!-- Tombol Desktop (Hanya tampil di atas SM) -->
          <a
            href="#products"
            class="hidden sm:inline-flex items-center justify-center w-full sm:w-max px-6 py-3.5 rounded-full bg-primary text-white text-base font-semibold hover:bg-opacity-90 transition-all"
          >
            Selengkapnya
            <svg
              class="w-5 h-5 ml-2"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M7 17L17 7M17 7H7M17 7V17"></path>
            </svg>
          </a>
        </div>

        <div
          class="w-auto sm:w-1/2 aspect-square sm:aspect-auto sm:h-96 relative mx-6 sm:mx-4 md:mx-6 sm:ml-0 rounded-[2rem] overflow-hidden flex items-center justify-center shadow-sm"
        >
          <img 
            src="/products/kolase2.jpeg" 
            alt="Kolase Proyek" 
            class="w-full h-full object-cover" 
          />
        </div>

        <!-- Tombol Mobile (Hanya tampil di bawah foto pada layar kecil) -->
        <div class="px-6 pb-6 pt-4 sm:hidden w-full">
          <a
            href="#products"
            class="inline-flex items-center justify-center w-full px-6 py-3.5 rounded-full bg-primary text-white text-base font-semibold hover:bg-opacity-90 transition-all"
          >
            Selengkapnya
            <svg
              class="w-5 h-5 ml-2"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M7 17L17 7M17 7H7M17 7V17"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </Container>
</section>
