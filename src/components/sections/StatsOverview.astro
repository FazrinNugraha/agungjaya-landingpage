---
import Container from "../shared/Container.astro";
---

<section class="relative pt-16 md:pt-20 pb-12 reveal">
  <Container>
    <!-- Header aligned to same 12-col grid as content below -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 md:gap-6 mb-10">
      <div class="col-span-1 lg:col-span-12">
        <h2 class="text-4xl md:text-5xl font-bold text-heading-1 leading-tight">
          <span class="text-primary">Pembangun</span> Membentuk <br/>
          Cakrawala <span class="text-secondary">Masa Depan</span>
        </h2>
      </div>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 md:gap-6">
      
      <!-- Left 2x2 Stats -->
      <div class="col-span-1 lg:col-span-5 grid grid-cols-2 gap-3 sm:gap-4 md:gap-6">
        <!-- Stat 1 (Dark) -->
        <div class="p-4 sm:p-6 md:p-8 rounded-[1rem] md:rounded-[2rem] bg-primary text-white shadow-lg shadow-primary/20 flex flex-col justify-center transform hover:-translate-y-1 transition-transform">
          <h3 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-1 sm:mb-3 md:mb-5 text-white">17K+</h3>
          <p class="text-xs sm:text-sm md:text-base text-blue-100 font-medium">Visi Terwujud</p>
        </div>
        <!-- Stat 2 -->
        <div class="p-4 sm:p-6 md:p-8 rounded-[1rem] md:rounded-[2rem] bg-box-bg border border-box-border text-heading-1 shadow-lg shadow-box-shadow flex flex-col justify-center transform hover:-translate-y-1 transition-transform">
          <h3 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-1 sm:mb-3 md:mb-5 text-heading-1">25+</h3>
          <p class="text-xs sm:text-sm md:text-base text-heading-3 font-medium">Tahun Bangun</p>
        </div>
        <!-- Stat 3 -->
        <div class="p-4 sm:p-6 md:p-8 rounded-[1rem] md:rounded-[2rem] bg-box-bg border border-box-border text-heading-1 shadow-lg shadow-box-shadow flex flex-col justify-center transform hover:-translate-y-1 transition-transform">
          <h3 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-1 sm:mb-3 md:mb-5 text-heading-1">150+</h3>
          <p class="text-xs sm:text-sm md:text-base text-heading-3 font-medium">Penghargaan</p>
        </div>
        <!-- Stat 4 -->
        <div class="p-4 sm:p-6 md:p-8 rounded-[1rem] md:rounded-[2rem] bg-box-bg border border-box-border text-heading-1 shadow-lg shadow-box-shadow flex flex-col justify-center transform hover:-translate-y-1 transition-transform">
          <h3 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-1 sm:mb-3 md:mb-5 text-heading-1">25+</h3>
          <p class="text-xs sm:text-sm md:text-base text-heading-3 font-medium">Koleksi Proyek</p>
        </div>
      </div>

      <!-- Right Feature Card -->
      <div class="col-span-1 lg:col-span-7 bg-box-bg border border-box-border shadow-lg shadow-box-shadow rounded-2xl md:rounded-[2rem] flex flex-col sm:flex-row overflow-hidden transform hover:-translate-y-1 transition-transform">
        <div class="p-6 sm:p-8 md:p-10 flex-1 flex flex-col justify-center items-start">
          <p class="text-base sm:text-lg md:text-xl font-medium text-heading-2 leading-relaxed mb-8 md:mb-10 max-w-sm">
            Menyelaraskan Alam — Kearifan Ekologis Bertemu Kecanggihan Arsitektur, Menciptakan Komunitas Tangguh untuk Generasi Mendatang
          </p>
          <a href="#products" class="inline-flex items-center justify-center w-full sm:w-max px-6 py-3.5 rounded-full bg-primary text-white text-base font-semibold hover:bg-opacity-90 transition-all">
            Selengkapnya
            <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7V17" />
            </svg>
          </a>
        </div>
        <div class="w-full sm:w-[45%] h-56 sm:h-auto bg-slate-100 dark:bg-slate-800 relative m-0 sm:m-4 md:m-6 sm:ml-0 sm:rounded-2xl overflow-hidden">
           <!-- The image placeholder area -->
           <div class="absolute inset-0 flex flex-col items-center justify-center">
             <svg class="w-8 h-8 text-gray-400 dark:text-gray-500 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
             </svg>
             <span class="text-sm text-gray-500 dark:text-gray-400 font-medium">Upload Gambar Proyek</span>
           </div>
           
           <!-- Uncomment this image tag to use it -->
           <!-- <img src="/assets/images/placeholder.jpg" alt="Building Architecture" class="absolute inset-0 w-full h-full object-cover" /> -->
        </div>
      </div>

    </div>
  </Container>
</section>
