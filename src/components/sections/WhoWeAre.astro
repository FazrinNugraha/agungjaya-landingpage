---
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";

export interface Props {
  className?: string;
}

const { className } = Astro.props;

const features = [
  "Renovasi Rumah",
  "Hunian Residensial",
  "Pembangunan Rumah",
  "Kebutuhan Kantor",
  "Kebutuhan Ruko",
  "Lokasi Komersial",
];
---

<section id="about" class={`relative reveal ${className}`}>
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
      <!-- Left Side -->
      <div class="flex flex-col gap-6 justify-center">
        <div>
          <span
            class="text-primary font-bold text-sm md:text-base tracking-wide flex items-center gap-2 mb-2"
          >
            Tentang Kami
          </span>
          <h2
            class="text-heading-1 text-3xl sm:text-4xl md:text-[2.75rem] font-bold mt-2 leading-[1.2]"
          >
            Partner Terpercaya untuk <br class="hidden lg:block" /> Kebutuhan Aluminium
            & <br class="hidden lg:block" /> Kaca Berkualitas.
          </h2>
        </div>

        <div class="space-y-6 mt-4">
          <Paragraph>
            Kami adalah penyedia jasa pembuatan dan pemasangan produk aluminium
            serta kaca yang berlokasi di Jakarta Timur. Agungjaya Aluminium
            melayani pengerjaan kusen, pintu, jendela, hingga partisi rumah
            dengan standar tinggi yang mengutamakan kualitas.
          </Paragraph>
          <Paragraph>
            Fokus utama kami ada pada kerapian hasil pengerjaan dan kekuatan
            struktur. Dengan tenaga kerja yang sudah terbiasa menangani berbagai
            kondisi di lapangan, kami memastikan setiap material aluminium
            terpasang dengan presisi dan berfungsi dengan baik selama
            bertahun-tahun.
          </Paragraph>
        </div>
      </div>

      <!-- Right Side -->
      <div class="flex flex-col gap-10 md:gap-12 lg:pt-4">
        <!-- Top: 2 Images Side by Side -->
        <div class="flex gap-4 sm:gap-6">
          <div
            class="w-1/2 aspect-[4/3] rounded-2xl overflow-hidden bg-slate-200 dark:bg-slate-800 relative group shadow-sm"
          >
            <img
              src="/products/utama.jpeg"
              alt="Utama"
              class="w-full h-full object-cover transition-transform group-hover:scale-105"
            />
          </div>
          <div
            class="w-1/2 aspect-[4/3] rounded-2xl overflow-hidden bg-slate-200 dark:bg-slate-800 relative group shadow-sm"
          >
            <img
              src="/products/lagikerja.jpeg"
              alt="Lagi Kerja"
              class="w-full h-full object-cover transition-transform group-hover:scale-105"
            />
          </div>
        </div>

        <!-- Bottom: We Come With -->
        <div>
          <h3 class="text-2xl sm:text-[1.75rem] font-bold text-heading-1 mb-8">
            Kami Melayani :
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-5 gap-x-4">
            {
              features.map((feature) => (
                <div class="flex items-center gap-4">
                  <svg
                    class="w-6 h-6 text-secondary flex-shrink-0"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path d="M12 3L2 12h3v8h5v-6h4v6h5v-8h3L12 3z" />
                  </svg>
                  <span class="text-heading-3 text-[15px] sm:text-base font-medium">
                    {feature}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
