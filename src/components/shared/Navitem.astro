---
export interface Props{
    href:string,
    text:string,
}
const {href, text} = Astro.props
---
<li>
    <a href={href} class="block w-full text-center lg:text-left duration-300 font-medium ease-linear text-slate-700 dark:text-slate-200 hover:text-primary hover:bg-slate-100 dark:hover:bg-slate-800 py-2 sm:py-2.5 px-4 rounded-xl transition-all">
    {text}
    </a>
</li>