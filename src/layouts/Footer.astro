---
import Container from "../components/shared/Container.astro";
import Paragraph from "../components/shared/Paragraph.astro";

const footerProduk = [
  { itemText: "Pintu Aluminium", itemLink: "#products" },
  { itemText: "Jendela Aluminium", itemLink: "#products" },
  { itemText: "Partisi Kaca", itemLink: "#products" },
  { itemText: "Kusen Aluminium", itemLink: "#products" },
];

const footerLayanan = [
  { itemText: "Konsultasi Gratis", itemLink: "#cta" },
  { itemText: "Pemasangan", itemLink: "#cta" },
  { itemText: "Garansi", itemLink: "#faq" },
  { itemText: "Perawatan", itemLink: "#faq" },
];

const footerPerusahaan = [
  { itemText: "Tentang Kami", itemLink: "#about" },
  { itemText: "Produk", itemLink: "#products" },
  { itemText: "FAQ", itemLink: "#faq" },
  { itemText: "Kontak", itemLink: "#cta" },
];
---

<div class="relative mt-16">
  <span class="w-20 h-20 rounded-full bg-gradient-to-br from-blue-400 to-primary absolute left-1/3 bottom-1/3"></span>
  <span class="w-40 h-40 rounded-full bg-gradient-to-br from-blue-300 via-primary to-blue-700 absolute right-1 top-2/4"></span>
  <span class="w-40 h-40 rounded-full bg-gradient-to-br from-blue-400 to-primary absolute right-1/4 bottom-0"></span>
  <span class="w-20 h-20 rounded-full bg-gradient-to-br from-blue-500 to-primary absolute right-1/3 top-1/3"></span>
  <span class="w-40 h-40 rounded-full bg-gradient-to-br from-blue-500 to-primary absolute left-0 top-1/3"></span>

  <footer class="relative bg-gradient-to-tr from-slate-100/85 to-zinc-200/85 dark:from-slate-800/85 dark:to-zinc-800/85 pt-28 rounded-t-3xl backdrop-blur-md">
    <Container className="pb-8 relative overflow-auto">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 relative">
        
        <!-- Brand Column -->
        <div class="col-span-2 lg:col-span-1 h-auto flex flex-col">
          <div class="h-full">
            <a href="/" class="relative flex items-center gap-3">
              <div class="inline-flex text-xl font-bold tracking-wide text-heading-1">
                AGUNG JAYA
              </div>
            </a>
            <Paragraph className={"mt-6"}>
              Spesialis produk aluminium premium untuk pintu, jendela, dan partisi. Melayani area Jabodetabek dan sekitarnya.
            </Paragraph>
          </div>

          <!-- Social Links -->
          <div class="min-h-max flex items-center gap-4 text-heading-3 mt-8">
            <a href="#" aria-label="WhatsApp" class="transition hover:text-primary hover:scale-110">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
              </svg>
            </a>
            <a href="#" aria-label="Instagram" class="transition hover:text-primary hover:scale-110">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
            </a>
            <a href="#" aria-label="TikTok" class="transition hover:text-primary hover:scale-110">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- Produk Column -->
        <div>
          <h3 class="text-heading-1 font-semibold text-sm mb-6">Produk</h3>
          <ul class="space-y-4">
            {footerProduk.map((item) => (
              <li>
                <a href={item.itemLink} class="text-heading-3 text-sm hover:text-primary transition">{item.itemText}</a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Layanan Column -->
        <div>
          <h3 class="text-heading-1 font-semibold text-sm mb-6">Layanan</h3>
          <ul class="space-y-4">
            {footerLayanan.map((item) => (
              <li>
                <a href={item.itemLink} class="text-heading-3 text-sm hover:text-primary transition">{item.itemText}</a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Perusahaan Column -->
        <div>
          <h3 class="text-heading-1 font-semibold text-sm mb-6">Perusahaan</h3>
          <ul class="space-y-4">
            {footerPerusahaan.map((item) => (
              <li>
                <a href={item.itemLink} class="text-heading-3 text-sm hover:text-primary transition">{item.itemText}</a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </Container>

    <div class="py-4 relative border-t border-box-border">
      <Container>
        <div class="flex justify-between items-center gap-6 text-sm text-heading-3">
          <div>
            &copy; <span id="year"></span> AGUNG JAYA. Hak cipta dilindungi.
          </div>
          <div class="text-heading-3">
            Dibuat dengan ❤️ di Indonesia
          </div>
        </div>
      </Container>
    </div>
  </footer>
</div>

<script>
  document.getElementById('year')!.textContent = new Date().getFullYear().toString();
</script>
