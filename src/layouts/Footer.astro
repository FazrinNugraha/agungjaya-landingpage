---
import Container from "../components/shared/Container.astro";
import Paragraph from "../components/shared/Paragraph.astro";
import { Image } from "astro:assets";
import logoAgungJaya from "../assets/images/logoAGUNGJAYA.jpeg";
---

<div class="relative mt-16">
  <span class="w-20 h-20 rounded-full bg-gradient-to-br from-blue-400 to-primary absolute left-1/3 bottom-1/3"></span>
  <span class="w-40 h-40 rounded-full bg-gradient-to-br from-blue-300 via-primary to-blue-700 absolute right-1 top-2/4"></span>
  <span class="w-40 h-40 rounded-full bg-gradient-to-br from-blue-400 to-primary absolute right-1/4 bottom-0"></span>
  <span class="w-20 h-20 rounded-full bg-gradient-to-br from-blue-500 to-primary absolute right-1/3 top-1/3"></span>
  <span class="w-40 h-40 rounded-full bg-gradient-to-br from-blue-500 to-primary absolute left-0 top-1/3"></span>

  <footer class="relative bg-gradient-to-tr from-slate-100/85 to-zinc-200/85 dark:from-slate-800/85 dark:to-zinc-800/85 pt-20 rounded-t-3xl backdrop-blur-md">
    <!-- TEST COMMENT: Ini adalah komentar percobaan agar fitur Accept/Reject muncul (Silakan dicoba di tab file ini) -->
    <Container className="relative overflow-auto">
      <!-- Top Section -->
      <div class="flex flex-col lg:flex-row justify-between items-start gap-10 lg:gap-20 pb-16">
        <div class="lg:w-3/5">
          <h2 class="text-3xl lg:text-5xl font-bold text-heading-1 mb-8 leading-tight">
            Waktunya beralih ke desain residensial elegan, <br/>
            <span class="text-heading-3 font-normal text-2xl lg:text-4xl mt-2 block">dengan aluminium premium</span>
          </h2>
          <div class="flex flex-col sm:flex-row gap-4 sm:gap-8 mt-8">
            <div class="flex items-center gap-3">
              <div class="w-6 h-6 flex items-center justify-center rounded-full bg-green-500 text-white shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
              </div>
              <span class="text-heading-3 font-medium">Berpengalaman lebih dari 10 tahun</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-6 h-6 flex items-center justify-center rounded-full bg-green-500 text-white shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
              </div>
              <span class="text-heading-3 font-medium">Dukungan material terkini</span>
            </div>
          </div>
        </div>
        
        <div class="lg:w-2/5 flex flex-col gap-6 lg:pl-10">
          <Paragraph>
            Dengan meningkatkan efektivitas desain dan fungsionalitas, penggunaan aluminium premium menjadi solusi terbaik dan ekonomis untuk bangunan Anda.
          </Paragraph>
          <a href="#cta" class="inline-flex justify-center items-center gap-2 px-8 py-3.5 rounded-full bg-heading-1 text-white dark:text-black hover:opacity-90 w-max font-medium transition shadow-md">
            Hubungi kami
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </a>
        </div>
      </div>

      <!-- Middle Section -->
      <div class="flex flex-col lg:flex-row justify-between items-center gap-8 py-10 border-t border-box-border/30">
        <div class="flex items-center gap-3">
          <a href="/" class="relative flex items-center gap-3">
            <div class="relative h-10 sm:h-12 w-auto overflow-hidden flex rounded-lg shadow-sm border border-box-border/50 bg-white">
              <Image src={logoAgungJaya} alt="Logo Agung Jaya" width={200} height={100} class="w-auto h-full object-contain" />
            </div>
            <div class="inline-flex text-base sm:text-lg font-bold text-heading-1 tracking-wide">
              AGUNG JAYA
            </div>
          </a>
        </div>
        
        <ul class="flex flex-wrap justify-center gap-x-8 gap-y-4 text-sm font-medium text-heading-3">
          <li><a href="#" class="hover:text-primary transition">Beranda</a></li>
          <li><a href="#about" class="hover:text-primary transition">Tentang Kami</a></li>
          <li><a href="#products" class="hover:text-primary transition">Product</a></li>
          <li><a href="#faq" class="hover:text-primary transition">FAQ</a></li>
          <li><a href="#cta" class="hover:text-primary transition">Kontak</a></li>
        </ul>

        <div class="flex items-center gap-3 text-heading-3">
          <a href="https://wa.me/6282261018391" aria-label="WhatsApp" class="w-9 h-9 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center transition hover:text-green-500 hover:bg-gray-300 dark:hover:bg-gray-600">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.487-1.761-1.66-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
          </a>
          <a href="https://www.instagram.com/agungjaya_aluminiumm?igsh=MWJ0NHhpenRtNXJ0" aria-label="Instagram" class="w-9 h-9 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center transition hover:text-primary hover:bg-gray-300 dark:hover:bg-gray-600">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
        </div>
      </div>
    </Container>

    <!-- Bottom Section -->
    <div class="py-6 relative border-t border-box-border/60">
      <Container>
        <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-heading-3">
          <div>
            &copy; <span id="year"></span> Agung Jaya. Hak cipta dilindungi.
          </div>
          <div class="flex gap-6">
            <a href="#" class="hover:text-primary transition">Terms of Service</a>
            <a href="#" class="hover:text-primary transition">Privacy Policy</a>
          </div>
        </div>
      </Container>
    </div>
  </footer>
</div>

<script>
  document.getElementById('year')!.textContent = new Date().getFullYear().toString();
</script>
